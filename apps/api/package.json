{
  "name": "@clarity/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test --test-concurrency=1 test/*.test.ts",
    "seed": "tsx src/scripts/loadSeeds.ts",
    "verify:mvp": "npm run verify:mvp:raw",
    "verify:mvp:raw": "tsx src/scripts/verifyMvp.ts",
    "verify:static:raw": "tsx src/scripts/verifyStaticServing.ts"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/cors": "^10.0.2",
    "@clarity/shared": "0.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
