{
  "name": "clarity-ai-transparent-dating",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "./scripts/setup/bootstrap.sh",
    "dev": "./scripts/dev/start-all.sh",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:shared": "npm --workspace packages/shared run dev",
    "build": "node scripts/quality/run-with-timeout.mjs 120000 npm run build:raw",
    "build:raw": "npm --workspace packages/shared run build && npm --workspace apps/api run build && npm --workspace apps/web run build",
    "start": "npm --workspace apps/api run start",
    "test": "node scripts/quality/run-with-timeout.mjs 60000 npm run test:raw",
    "test:raw": "npm --workspace apps/api run test && npm --workspace apps/web run test && npm run test:signal-engine",
    "test:signal-engine": ".venv/bin/python -m pytest -q --disable-warnings services/signal-engine/tests",
    "typecheck": "node scripts/quality/run-with-timeout.mjs 120000 npm run typecheck:raw",
    "typecheck:raw": "npm --workspace packages/shared run typecheck && npm --workspace apps/api run typecheck && npm --workspace apps/web run typecheck",
    "quality": "./scripts/quality/verify.sh",
    "seed": "npm --workspace apps/api run seed",
    "verify:mvp": "node scripts/quality/run-with-timeout.mjs 30000 npm --workspace apps/api run verify:mvp:raw",
    "verify:static": "node scripts/quality/run-with-timeout.mjs 30000 npm --workspace apps/api run verify:static:raw",
    "validate:resource-registry": "node scripts/governance/validate-resource-registry.mjs",
    "validate:donor-provenance": "node scripts/governance/validate-donor-provenance.mjs --donor-root ..",
    "validate:signal-registries": "node scripts/governance/validate-signal-registries.mjs",
    "validate:training-source-registry": "node scripts/governance/validate-training-source-registry.mjs",
    "validate:research-source-registry": "node scripts/governance/validate-research-source-registry.mjs",
    "validate:python-lock": "node scripts/governance/validate-python-lock.mjs",
    "validate:claims": "node scripts/governance/validate-claims.mjs",
    "check:restricted-artifacts": "node scripts/governance/check-restricted-artifacts.mjs",
    "check:no-raw-content": "node scripts/governance/check-no-raw-content.mjs",
    "check:signal-safety-language": "node scripts/governance/check-signal-safety-language.mjs",
    "check:signal-domain-residue": "node scripts/governance/check-signal-domain-residue.mjs",
    "check:secrets": "node scripts/governance/check-secrets.mjs",
    "check:public-copy": "node scripts/governance/check-public-copy.mjs",
    "check:t1-production-bundle": "node scripts/governance/check-t1-production-bundle.mjs"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  }
}
